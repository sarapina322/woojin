{% comment %}
  Unified education entry renderer for both RenderCV and JSONResume formats.
{% endcomment %}

<ul class="card-text font-weight-light list-group list-group-flush">
  {% for entry in entries %}
    {% assign start_raw = entry.start_date | default: entry.startDate %}
    {% assign end_raw = entry.end_date | default: entry.endDate %}

    {% assign start_label = '' %}
    {% if start_raw %}
      {% if start_raw contains '-' %}
        {% assign start_label = start_raw | date: '%Y.%m' %}
      {% else %}
        {% assign start_label = start_raw %}
      {% endif %}
    {% endif %}

    {% assign end_label = 'Present' %}
    {% if end_raw %}
      {% if end_raw contains '-' %}
        {% assign end_label = end_raw | date: '%Y.%m' %}
      {% else %}
        {% assign end_label = end_raw %}
      {% endif %}
    {% endif %}

    {% assign date_label = '' %}
    {% if start_label != '' %}
      {% assign date_label = start_label | append: ' - ' | append: end_label %}
    {% endif %}

    <li class="list-group-item">
      <div class="row">
        <div class="col-12 col-md-3 date-column">
          {% if date_label != '' %}
            <span class="cv-date-pill">{{ date_label }}</span>
          {% endif %}

          {% if entry.location %}
            <p class="location">
              <i class="fa-solid fa-location-dot iconlocation"></i>
              {{ entry.location }}
            </p>
          {% endif %}
        </div>

        <div class="col-12 col-md-9 mt-2 mt-md-0">
          {% assign study_type = entry.studyType | default: entry.degree | default: '' %}
          {% if entry.url %}
            {% if entry.url contains '://' %}
              {% assign study_href = entry.url %}
            {% else %}
              {% assign study_href = entry.url | relative_url %}
            {% endif %}
            <h6 class="title font-weight-bold mb-1">
              <a href="{{ study_href }}" target="_blank" rel="noopener noreferrer">{{ study_type }}</a>
            </h6>
          {% elsif study_type != '' %}
            <h6 class="title font-weight-bold mb-1">{{ study_type }}</h6>
          {% endif %}

          {% if entry.institution %}
            <h6 class="mb-1" style="font-size: 0.95rem">{{ entry.institution }}</h6>
          {% endif %}

          {% if entry.area %}
            <h6 class="mb-2" style="font-size: 0.95rem; font-style: italic">{{ entry.area }}</h6>
          {% endif %}

          {% if entry.score %}
            <p class="mb-2">{{ entry.score }}</p>
          {% endif %}

          {% if entry.courses or entry.highlights %}
            <ul class="items">
              {% for item in entry.courses %}
                <li>
                  <span class="item">{{ item }}</span>
                </li>
              {% endfor %}
              {% for item in entry.highlights %}
                <li>
                  <span class="item">{{ item | markdownify | remove: '<p>' | remove: '</p>' }}</span>
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      </div>
    </li>
  {% endfor %}
</ul>
