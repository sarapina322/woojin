{% comment %}
  Unified work/experience entry renderer for both RenderCV and JSONResume formats.
{% endcomment %}

<ul class="card-text font-weight-light list-group list-group-flush">
  {% for entry in entries %}
    {% assign start_raw = entry.start_date | default: entry.startDate %}
    {% assign end_raw = entry.end_date | default: entry.endDate %}

    {% assign start_label = '' %}
    {% if start_raw %}
      {% if start_raw contains '-' %}
        {% assign start_label = start_raw | date: '%Y.%m' %}
      {% else %}
        {% assign start_label = start_raw %}
      {% endif %}
    {% endif %}

    {% assign end_label = 'Present' %}
    {% if end_raw %}
      {% if end_raw contains '-' %}
        {% assign end_label = end_raw | date: '%Y.%m' %}
      {% else %}
        {% assign end_label = end_raw %}
      {% endif %}
    {% endif %}

    {% assign date_label = '' %}
    {% if start_label != '' %}
      {% assign date_label = start_label | append: ' - ' | append: end_label %}
    {% endif %}

    <li class="list-group-item">
      <div class="row">
        <div class="col-12 col-md-3 date-column">
          {% if date_label != '' %}
            <span class="cv-date-pill">{{ date_label }}</span>
          {% endif %}

          {% if entry.location %}
            <p class="location">
              <i class="fa-solid fa-location-dot iconlocation"></i>
              {{ entry.location }}
            </p>
          {% endif %}
        </div>

        <div class="col-12 col-md-9 mt-2 mt-md-0">
          {% assign position_title = entry.position | default: '' %}
          {% assign position_href = '' %}
          {% if entry.url %}
            {% if entry.url contains '://' %}
              {% assign position_href = entry.url %}
            {% else %}
              {% assign position_href = entry.url | relative_url %}
            {% endif %}
          {% elsif entry.evidence and entry.evidence.first %}
            {% assign first_ev_path = entry.evidence.first.url | default: entry.evidence.first.path | default: entry.evidence.first %}
            {% if first_ev_path contains '://' %}
              {% assign position_href = first_ev_path %}
            {% else %}
              {% assign position_href = first_ev_path | relative_url %}
            {% endif %}
          {% endif %}

          {% if position_title != '' and position_href != '' %}
            <h6 class="title font-weight-bold mb-1">
              <a href="{{ position_href }}" target="_blank" rel="noopener noreferrer">{{ position_title }}</a>
            </h6>
          {% elsif position_title != '' %}
            <h6 class="title font-weight-bold mb-1">{{ position_title }}</h6>
          {% endif %}

          {% assign company_name = entry.name | default: entry.company | default: entry.organization %}
          {% if company_name %}
            <h6 class="mb-1" style="font-size: 0.95rem">{{ company_name }}</h6>
          {% endif %}

          {% if entry.summary %}
            <h6 class="mb-2" style="font-size: 0.95rem; font-style: italic">
              {{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}
            </h6>
          {% endif %}

          {% if entry.highlights %}
            <ul class="items">
              {% for item in entry.highlights %}
                <li>
                  <span class="item">{{ item | markdownify | remove: '<p>' | remove: '</p>' }}</span>
                </li>
              {% endfor %}
            </ul>
          {% endif %}

          {% if entry.evidence %}
            <details class="cv-evidence mt-2">
              <summary>View Evidence</summary>
              <div class="cv-evidence-links">
                {% for ev in entry.evidence %}
                  {% assign ev_label = ev.label | default: ev.title | default: 'Evidence' %}
                  {% assign ev_path = ev.url | default: ev.path | default: ev %}
                  {% if ev_path contains '://' %}
                    {% assign ev_href = ev_path %}
                  {% else %}
                    {% assign ev_href = ev_path | relative_url %}
                  {% endif %}
                  <a href="{{ ev_href }}" target="_blank" rel="noopener noreferrer" class="btncv">{{ ev_label }}</a>
                {% endfor %}
              </div>

              <div class="cv-evidence-grid">
                {% for ev in entry.evidence %}
                  {% assign ev_label = ev.label | default: ev.title | default: 'Evidence' %}
                  {% assign ev_path = ev.url | default: ev.path | default: ev %}
                  {% assign ev_path_down = ev_path | downcase %}
                  {% assign is_image = false %}
                  {% if ev_path_down contains '.png'
                    or ev_path_down contains '.jpg'
                    or ev_path_down contains '.jpeg'
                    or ev_path_down contains '.webp'
                    or ev_path_down contains '.gif'
                  %}
                    {% assign is_image = true %}
                  {% endif %}
                  {% if is_image %}
                    {% if ev_path contains '://' %}
                      {% assign ev_src = ev_path %}
                    {% else %}
                      {% assign ev_src = ev_path | relative_url %}
                    {% endif %}
                    <a href="{{ ev_src }}" target="_blank" rel="noopener noreferrer" class="cv-evidence-card">
                      <img src="{{ ev_src }}" alt="{{ ev_label }}">
                      <span>{{ ev_label }}</span>
                    </a>
                  {% endif %}
                {% endfor %}
              </div>
            </details>
          {% endif %}
        </div>
      </div>
    </li>
  {% endfor %}
</ul>
