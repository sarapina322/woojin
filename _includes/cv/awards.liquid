{% comment %}
  Unified awards entry renderer for both formats.
{% endcomment %}

<ul class="card-text font-weight-light list-group list-group-flush">
  {% for entry in entries %}
    {% assign date_label = '' %}
    {% if entry.date %}
      {% if entry.date contains '-' %}
        {% assign date_label = entry.date | date: '%Y.%m' %}
      {% else %}
        {% assign date_label = entry.date %}
      {% endif %}
    {% endif %}

    <li class="list-group-item">
      <div class="row">
        <div class="col-12 col-md-3 date-column">
          {% if date_label != '' %}
            <span class="cv-date-pill">{{ date_label }}</span>
          {% endif %}
        </div>

        <div class="col-12 col-md-9 mt-2 mt-md-0">
          {% if entry.url %}
            {% if entry.url contains '://' %}
              {% assign award_href = entry.url %}
            {% else %}
              {% assign award_href = entry.url | relative_url %}
            {% endif %}
            <h6 class="title font-weight-bold mb-1">
              <a href="{{ award_href }}" target="_blank" rel="noopener noreferrer">{{ entry.title }}</a>
            </h6>
          {% elsif entry.title %}
            <h6 class="title font-weight-bold mb-1">{{ entry.title }}</h6>
          {% endif %}

          {% if entry.awarder %}
            <h6 class="mb-1" style="font-size: 0.95rem">{{ entry.awarder }}</h6>
          {% endif %}

          {% if entry.summary %}
            <p class="mb-2">{{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}</p>
          {% endif %}

          {% if entry.evidence %}
            <details class="cv-evidence mt-2">
              <summary>View Evidence</summary>
              <div class="cv-evidence-links">
                {% for ev in entry.evidence %}
                  {% assign ev_label = ev.label | default: ev.title | default: 'Evidence' %}
                  {% assign ev_path = ev.url | default: ev.path | default: ev %}
                  {% if ev_path contains '://' %}
                    {% assign ev_href = ev_path %}
                  {% else %}
                    {% assign ev_href = ev_path | relative_url %}
                  {% endif %}
                  <a href="{{ ev_href }}" target="_blank" rel="noopener noreferrer" class="btncv">{{ ev_label }}</a>
                {% endfor %}
              </div>
            </details>
          {% endif %}
        </div>
      </div>
    </li>
  {% endfor %}
</ul>
